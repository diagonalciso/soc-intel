# ── Application ───────────────────────────────────────────────
APP_NAME=CLAWINT
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
# Internal connector-to-API auth key — set to a different secret than SECRET_KEY
CONNECTOR_API_KEY=change-me-connector-key
ALLOWED_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clawint
POSTGRES_USER=clawint
POSTGRES_PASSWORD=clawint

# ── OpenSearch ────────────────────────────────────────────────
OPENSEARCH_HOST=http://opensearch:9200

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=clawint

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=clawint
RABBITMQ_PASS=clawint

# ── MinIO ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=clawint
MINIO_ROOT_PASSWORD=clawint123
MINIO_BUCKET=clawint

# ── Tor ──────────────────────────────────────────────────────
TOR_PROXY=socks5://tor:9050

# ── Default admin (first-run seed) ───────────────────────────
# These are only used on first startup when no users exist.
# Change all of these before deploying.
SEED_ORG=CLAWINT
SEED_EMAIL=admin@clawint.local
SEED_USERNAME=admin
SEED_PASSWORD=changeme123!

# ── API Keys (optional — add as needed) ──────────────────────
# Free / community tier:
OTX_API_KEY=               # AlienVault OTX — otx.alienvault.com (free)
GREYNOISE_API_KEY=          # GreyNoise community — greynoise.io (free tier available)
ABUSEIPDB_API_KEY=          # AbuseIPDB — abuseipdb.com (free tier available)

# Paid / higher-tier:
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
HUDSONROCK_API_KEY=
HIBP_API_KEY=
CRIMINAL_IP_API_KEY=
PULSEDIVE_API_KEY=
FLARE_API_KEY=
DARKOWL_API_KEY=
RECORDED_FUTURE_API_KEY=
INTEL471_USERNAME=
INTEL471_API_KEY=
VULNCHECK_API_KEY=
URLSCAN_API_KEY=
HYBRID_ANALYSIS_API_KEY=

# ── TAXII extra servers (optional) ───────────────────────────
# Comma-separated: "name|url|username|password,name2|url2|user2|pass2"
TAXII_EXTRA_SERVERS=
